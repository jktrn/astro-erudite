---
import MetaPost from "@/components/MetaPost.astro"
import PostActions from "@/components/PostActions.astro"
import ScrollToTop from "@/components/ScrollToTop.astro"
import SeriesReader from "@/components/SeriesReader.astro"
import TableOfContents from "@/components/TableOfContents.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts, getSubposts, pageTitle } from "@/lib/content"
import { formatDate, isSubpost, subpostSlug } from "@/lib/utils"
import { Image } from "astro:assets"
import { getEntries, render, type CollectionEntry } from "astro:content"

export async function getStaticPaths() {
  const posts = await getPosts()
  const series = await getSubposts()
  return posts.flatMap((parent, i) => {
    const chain = [parent, ...(series.get(parent.id) ?? [])]
    return chain.map((post) => ({
      params: { id: post.id },
      props: { post, chain, prev: posts[i + 1], next: posts[i - 1] },
    }))
  })
}

type Props = {
  post: CollectionEntry<"blog">
  chain: CollectionEntry<"blog">[]
  prev?: CollectionEntry<"blog">
  next?: CollectionEntry<"blog">
}

const { post, chain, prev, next } = Astro.props
const [parent] = chain
const rendered = await Promise.all(
  chain.map(async (entry) => ({
    entry,
    ...(await render(entry)),
    authors: await getEntries(entry.data.authors),
  })),
)

const sections = rendered.map(({ entry, headings }, i) => ({
  id: i === 0 ? undefined : subpostSlug(entry.id),
  label: entry.data.title,
  open: entry.id === post.id,
  headings: headings.filter(
    ({ depth, text }) => depth >= 2 && depth <= 4 && text.trim(),
  ),
}))
const hasToc =
  sections.length > 1 || sections.some(({ headings }) => headings.length > 0)

const crumbs = [{ label: parent.data.title, href: `/blog/${parent.id}` }]
if (isSubpost(post.id)) {
  crumbs.push({ label: post.data.title, href: `/blog/${post.id}` })
}
---

<Layout crumbs={crumbs}>
  <MetaPost
    slot="head"
    post={post}
    canonical={isSubpost(post.id) ? `/blog/${parent.id}` : undefined}
  />
  {hasToc && (
      <TableOfContents
        slot="toc"
        title={parent.data.title}
        sections={sections}
      />
    )}
  <PostActions slot="actions" prev={prev} next={next} />
  <ScrollToTop floating />
  {rendered.map(({ entry, Content, authors }, i) => (
      <article
        id={i === 0 ? undefined : subpostSlug(entry.id)}
        data-url={`/blog/${entry.id}`}
        data-title={pageTitle(entry.data.title)}
        data-embedded={i > 0 || undefined}
      >
        <header>
          <h1>{entry.data.title}</h1>
          <post-meta>
            {authors.length > 0 && (
              <post-authors>
                <author-avatars>
                  {authors.map((author) => (
                    <img
                      src={author.data.avatar}
                      alt={author.data.name}
                      width="18"
                      height="18"
                    />
                  ))}
                </author-avatars>
                <author-names>
                  {authors.map((author, j) => (
                    <>{j > 0 && ", "}<a href={`/authors/${author.id}`}>{author.data.name}</a></>
                  ))}
                </author-names>
              </post-authors>
            )}
            <time datetime={entry.data.date.toISOString()}
              >{formatDate(entry.data.date)}</time
            >
            {entry.data.tags && (
              <post-tags>
                {entry.data.tags.map((tag) => (
                  <a href={`/tags/${tag}`}>#{tag}</a>
                ))}
              </post-tags>
            )}
          </post-meta>
          <p>{entry.data.description}</p>
        </header>
        {entry.data.image && (
          <post-banner>
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              width={1200}
              height={630}
              priority={entry.id === post.id || undefined}
            />
          </post-banner>
        )}
        <prose-content>
          <Content />
        </prose-content>
      </article>
    ))}
  {chain.length > 1 && <SeriesReader />}
</Layout>

<style>
  article[data-embedded] {
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-xl);
    border-block-start: 2px solid var(--border);
    scroll-margin-block-start: calc(-2px - 0.2 * var(--step-2));

    header h1 {
      font-size: var(--step-2);
    }
  }

  header {
    margin-block-end: var(--space-m);

    h1 {
      font-size: var(--step-3);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
    }

    post-meta {
      --underline: var(--muted-foreground);

      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-3xs);
      margin-block-start: var(--space-3xs);
      font-size: var(--step--1);
      color: var(--muted-foreground);

      post-authors {
        display: flex;
        align-items: center;
        gap: var(--space-3xs);

        author-avatars {
          display: flex;
          margin-block-end: -0.1em;

          img {
            border-radius: var(--radius-full);
            box-shadow: 0 0 0 1.5px var(--background);

            &:not(:first-child) {
              margin-inline-start: -0.375rem;
            }
          }
        }
      }

      post-authors ~ time::before {
        content: "·";
        margin-inline-end: var(--space-3xs);
      }

      post-tags {
        --underline: transparent;

        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3xs);

        a {
          color: color-mix(in oklab, var(--muted-foreground) 50%, transparent);

          &:hover {
            color: var(--foreground);
          }
        }
      }

      time ~ post-tags::before {
        content: "·";
      }

      a {
        color: var(--foreground);
      }
    }

    > p {
      margin-block-start: var(--space-2xs);
      font-size: var(--step--1);
      color: var(--muted-foreground);
    }
  }

  post-banner {
    display: block;
    margin-block-end: var(--space-m);

    :global(img) {
      inline-size: 100%;
      block-size: auto;
    }
  }
</style>
